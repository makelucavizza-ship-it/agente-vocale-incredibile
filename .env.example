# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL (sicuro da esporre al frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (sicuro da esporre al frontend — limitato dalle RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — MAI esporre al frontend, solo server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── VAPI ────────────────────────────────────────────────────────────────────
# API Key VAPI — trovata in dashboard.vapi.ai → Account → API Keys
VAPI_API_KEY=

# Webhook secret — trovato in dashboard.vapi.ai → Settings → Webhooks
VAPI_WEBHOOK_SECRET=

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── URL pubblica del sito ───────────────────────────────────────────────────
# Usato dai tool calls del webhook VAPI per richiamare i propri endpoint
# OBBLIGATORIO in produzione — senza questo i tool calls falliscono
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Crea un database gratuito su upstash.com → Redis → Create Database
# Copia le credenziali da: Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=
